{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "PuddingSnap",
  "version": "0.1.0",
  "identifier": "com.puddingsnap.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5175",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PuddingSnap",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "visible": false,
        "center": true,
        "dragDropEnabled": true,
        "decorations": false
      }
    ],
    "security": {
      "assetProtocol": {
        "scope": ["**"],
        "enable": true
      },
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png"
    ]
  },
  "plugins": {}
}
